rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 6. PII Isolation & Schema Constraints
    // Users collection: Private access only to the owner
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'photoURL'])
      );

      function isValidUser(user) {
        return user.userId == request.auth.uid
          && user.email is string && user.email.size() <= 128
          && (user.displayName == null || (user.displayName is string && user.displayName.size() <= 64))
          && (user.photoURL == null || (user.photoURL is string && user.photoURL.size() <= 512))
          && user.createdAt == (resource == null ? request.time : existing().createdAt);
      }
    }

    // Orders collection
    match /orders/{orderId} {
      // 8. Secure List Queries (The "Query Enforcer")
      // Explicitly evaluate resource.data.userId to force the client to query securely
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      
      // 1. The "Master Gate" (Relational Sync)
      // Check if user exists before creating an order
      allow create: if isSignedIn() 
        && isValidId(orderId)
        && isValidOrder(incoming())
        && incoming().userId == request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));

      // 4. Action-Based Update Pattern
      allow update: if isSignedIn() && isValidOrder(incoming()) && (
        // Action: Cancel Order (Only if pending)
        (isCancelAction() && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );

      function isValidOrder(order) {
        return order.userId == request.auth.uid
          && order.items is list && order.items.size() > 0 && order.items.size() <= 50
          && order.subtotal is number && order.subtotal >= 0
          && order.total is number && order.total >= 0
          && order.status in ['pending', 'preparing', 'ready', 'completed', 'cancelled']
          && order.createdAt == (resource == null ? request.time : existing().createdAt)
          && order.updatedAt == request.time;
      }

      function isCancelAction() {
        return incoming().status == 'cancelled' && incoming().userId == existing().userId;
      }
    }
  }
}
